############### PROBLEM ##################
######  Merge Sorting



Given an array of integers, nums,sort the array in non-decreasing order using the merge sort algorithm. Return the sorted array.

A sorted array in non-decreasing order is one in which each element is either greater than or equal to all the elements to its left in the array.


Example 1

          Input: nums = [7, 4, 1, 5, 3]
          
          Output: [1, 3, 4, 5, 7]
          
          Explanation: 1 <= 3 <= 4 <= 5 <= 7.
          
          Thus the array is sorted in non-decreasing order.

Example 2

          Input: nums = [5, 4, 4, 1, 1]
          
          Output: [1, 1, 4, 4, 5]
          
          Explanation: 1 <= 1 <= 4 <= 4 <= 5.
          
          Thus the array is sorted in non-decreasing order.


########### SOLUTION #################
 import java.util.*;
class Solution {
    public int[] mergeSort(int[] nums) {
        /* The steps be like
        step1:  Write a function
        step 2: Get the base condition
        step 3: divide array into two halves hypothetically
        step 4: Perform recursion
        step 5: and merge them using comparion into a temp variable 
        step 6: if any left overs on each half add them at the end
        step 7: add based on index wise to original array by copying ele ents from temp
        return ther array at the end


        */
    int n=nums.length;
    int low=0;
    int high=n-1;
    this.mergesorting(nums,low,high);
    return nums;

    } 

    public void mergesorting(int [] nums,int low,int high){

        if(low>=high) return;
        int mid=(low+high)/2;
        this.mergesorting(nums,low,mid);
        this.mergesorting(nums,mid+1,high);
        this.merging(nums,low,mid,high);

    }

    public int[] merging(int [] nums,int low,int mid,int high){
        ArrayList<Integer> temp =new ArrayList<>();
        int left=low;
        int right=mid+1;

        while(left<=mid && right<=high){

            if(nums[left]<=nums[right]){
                temp.add(nums[left]);
                left++;
            }
            else{
                temp.add(nums[right]);
                right++;

            }
        }

        while(left<=mid){
            temp.add(nums[left]);
            left ++;
        }

        while(right<=high){
            temp.add(nums[right]);
            right ++;
        }
        int i=low;

  


        for(int j=0;j<temp.size();j++){
            Integer[] arr = temp.toArray(new Integer[0]);
            nums[i]=arr[j];
            i++;
        }
        return nums;
    }


}
